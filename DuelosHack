-- ===================== CUCHILLO =====================
local function ToggleKnife(state)
    CONFIG.Knife = state
    print("🔪 Cuchillo: " .. (state and "ON" or "OFF"))
    local char = GetCharacter()
    if not char then return end
    local tool = char:FindFirstChildWhichIsA("Tool")
    if tool and state then
        tool.Parent = char
        task.wait(0.1)
        local activate = tool:FindFirstChild("Activate")
        if activate and activate:IsA("RemoteEvent") then
            activate:FireServer()
        end
    end
end

-- ===================== AIMBOT (CON VirtualInputManager) =====================
local function GetClosestEnemy()
    local enemies = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char then continue end
        local hum = char:FindFirstChild("Humanoid")
        if hum and hum.Health > 0 then
            table.insert(enemies, player)
        end
    end
    if #enemies == 0 then return nil end
    local cx, cy = Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2
    local closest, closestDist = nil, math.huge
    for _, enemy in ipairs(enemies) do
        local head = enemy.Character:FindFirstChild("Head")
        if head then
            local pos, _ = Camera:WorldToScreenPoint(head.Position)
            local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(cx, cy)).Magnitude
            if dist < closestDist then
                closestDist = dist
                closest = enemy
            end
        end
    end
    return closest
end

-- Disparar usando VirtualInputManager (más compatible en móvil)
local function FireWeapon()
    -- Presionar y soltar clic izquierdo
    VirtualInput:SendMouseButtonEvent(Enum.UserInputType.MouseButton1, 0, true, 1, 0)
    task.wait(0.05)
    VirtualInput:SendMouseButtonEvent(Enum.UserInputType.MouseButton1, 0, false, 1, 0)
end

-- Mover el mouse usando VirtualInputManager (movimiento absoluto)
local function MoveMouseTo(target, smooth)
    if not target then return end
    local head = target.Character:FindFirstChild("Head")
    if not head then return end
    local pos, _ = Camera:WorldToScreenPoint(head.Position)
    if not smooth then
        -- Movimiento instantáneo
        VirtualInput:SendMouseMoveEvent(pos.X, pos.Y, 0)
    else
        -- Movimiento suave (lerp)
        local cx, cy = Mouse.X, Mouse.Y
        for i = 1, 10 do
            local a = i / 10
            local tx = cx + (pos.X - cx) * a
            local ty = cy + (pos.Y - cy) * a
            VirtualInput:SendMouseMoveEvent(tx, ty, 0)
            task.wait(0.01)
        end
    end
    -- Si estamos en modo bannable, disparamos automáticamente
    if CONFIG.AimbotBannable then
        FireWeapon()
    end
end

-- ===================== ESP (BILLBOARD + SELECTIONBOX) =====================
local function ClearEsp()
    for _, obj in ipairs(EspBoxes) do
        pcall(function() obj:Destroy() end)
    end
    EspBoxes = {}
end

local function UpdateEsp()
    if not CONFIG.ESP then
        ClearEsp()
        return
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char then continue end
        local hum = char:FindFirstChild("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local nameTag = char:FindFirstChild("NameTagHack")
        if not nameTag then
            local bill = Instance.new("BillboardGui")
            bill.Name = "NameTagHack"
            bill.Size = UDim2.new(0, 120, 0, 30)
            bill.StudsOffset = Vector3.new(0, 2.5, 0)
            bill.AlwaysOnTop = true
            bill.Parent = char
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, 0, 1, 0)
            label.BackgroundTransparency = 1
            label.Text = player.Name
            label.TextColor3 = Color3.fromRGB(255,255,255)
            label.TextStrokeColor3 = Color3.fromRGB(0,0,0)
            label.TextStrokeTransparency = 0.3
            label.Font = Enum.Font.GothamBold
            label.TextSize = 16
            label.Parent = bill
            table.insert(EspBoxes, bill)
        end

        if CONFIG.Boxes then
            local head = char:FindFirstChild("Head")
            if head then
                local box = Instance.new("SelectionBox")
                box.Adornee = head
                box.Color3 = Color3.fromRGB(255, 0, 0)
                box.Transparency = 0.5
                box.LineThickness = 0.1
                box.Visible = true
                box.Parent = head
                table.insert(EspBoxes, box)
            end
        end

        if CONFIG.Hitbox then
            local parts = {char:FindFirstChild("UpperTorso"), char:FindFirstChild("LowerTorso"), char:FindFirstChild("LeftArm"), char:FindFirstChild("RightArm"), char:FindFirstChild("LeftLeg"), char:FindFirstChild("RightLeg")}
            for _, part in ipairs(parts) do
                if part then
                    local box = Instance.new("SelectionBox")
                    box.Adornee = part
                    box.Color3 = Color3.fromRGB(0, 200, 255)
                    box.Transparency = 0.5
                    box.LineThickness = 0.1
                    box.Visible = true
                    box.Parent = part
                    table.insert(EspBoxes, box)
                end
            end
        end
    end
end

-- ===================== INVISIBLE + BURBUJA + TECLA =====================
local function ApplyGhostInvisibility(state)
    CONFIG.Invisible = state
    local char = GetCharacter()
    if not char then return end

    local trans = state and 1 or 0
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = trans
        end
        if part:IsA("Decal") or part:IsA("Texture") then
            part.Transparency = trans
        end
    end

    local hum = GetHumanoid()
    if hum then
        hum.HealthDisplayDistance = state and 0 or 100
        hum.NameDisplayDistance = state and 0 or 100
    end

    if state then
        if not GhostHighlight then
            GhostHighlight = Instance.new("Highlight")
            GhostHighlight.Adornee = char
            GhostHighlight.FillColor = Color3.fromRGB(0, 200, 255)
            GhostHighlight.FillTransparency = 0.6
            GhostHighlight.OutlineColor = Color3.fromRGB(255,255,255)
            GhostHighlight.OutlineTransparency = 0.2
            GhostHighlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            GhostHighlight.Parent = char
        end
    else
        if GhostHighlight then
            GhostHighlight:Destroy()
            GhostHighlight = nil
        end
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = 0
            end
            if part:IsA("Decal") or part:IsA("Texture") then
                part.Transparency = 0
            end
        end
        if hum then
            hum.HealthDisplayDistance = 100
            hum.NameDisplayDistance = 100
        end
    end

    local bubble = char:FindFirstChild("GhostBubble")
    if CONFIG.GhostBubble and state then
        if not bubble then
            local ff = Instance.new("ForceField")
            ff.Name = "GhostBubble"
            ff.Visible = true
            ff.Parent = char
        end
    else
        if bubble then bubble:Destroy() end
    end

    print("👻 Fantasma: " .. (state and "ON" or "OFF"))
end

-- ===================== MOVIMIENTO =====================
local function ApplyMovementMods()
    local hum = GetHumanoid()
    if not hum then return end
    if CONFIG.Speed then
        hum.WalkSpeed = CONFIG.SpeedValue
    else
        hum.WalkSpeed = 16
    end
    if CONFIG.JumpPower then
        hum.JumpPower = CONFIG.JumpPowerValue
    else
        hum.JumpPower = 50
    end
end

local function SetupInfiniteJump()
    local hum = GetHumanoid()
    if not hum then return end
    if InfiniteJumpConnection then
        InfiniteJumpConnection:Disconnect()
        InfiniteJumpConnection = nil
    end
    if CONFIG.InfiniteJump then
        InfiniteJumpConnection = hum.StateChanged:Connect(function(old, new)
            if new == Enum.HumanoidStateType.Landed or new == Enum.HumanoidStateType.Freefall then
                if CONFIG.InfiniteJump then
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
        end)
    end
end

-- ===================== EVENTS (AUTO WIN) =====================
local function TriggerEvents()
    if not CONFIG.Events then return end
    print("⚡ Disparando eventos de victoria...")
    for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            pcall(function()
                if obj:IsA("RemoteEvent") then obj:FireServer("Win", "RoundWin")
                elseif obj:IsA("RemoteFunction") then obj:InvokeServer("Win", "RoundWin") end
            end)
        end
    end
end

-- ===================== TEXTURAS LISAS =====================
local function ApplySmoothTextures(state)
    CONFIG.SmoothTextures = state
    local mat = state and Enum.Material.Plastic or Enum.Material.SmoothPlastic
    for _, part in ipairs(workspace:GetDescendants()) do
        if part:IsA("BasePart") and not part:IsDescendantOf(LocalPlayer.Character) then
            pcall(function() part.Material = mat end)
        end
    end
    print("🧊 Texturas Lisas: " .. (state and "ON" or "OFF"))
end

